{
  "name": "@tgoliveira/outpost",
  "version": "1.1.0",
  "description": "A transactional outbox with pluggable transport for Next.js. Durable, at-most-once, auditable transactional email.",
  "keywords": [
    "outbox",
    "transactional-email",
    "email",
    "nextjs",
    "drizzle",
    "postgres",
    "clean-architecture",
    "idempotency",
    "suppression-list",
    "smtp",
    "resend"
  ],
  "license": "MIT",
  "author": "Engineering",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "styles.css",
    "README.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js",
      "require": "./dist/adapters/index.cjs"
    },
    "./drizzle": {
      "types": "./dist/adapters/drizzle/index.d.ts",
      "import": "./dist/adapters/drizzle/index.js",
      "require": "./dist/adapters/drizzle/index.cjs"
    },
    "./next": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js",
      "require": "./dist/http/index.cjs"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "import": "./dist/admin/index.js",
      "require": "./dist/admin/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./react/client": {
      "types": "./dist/react/client.d.ts",
      "import": "./dist/react/client.js",
      "require": "./dist/react/client.cjs"
    },
    "./styles.css": "./styles.css",
    "./workers": {
      "types": "./dist/workers/index.d.ts",
      "import": "./dist/workers/index.js",
      "require": "./dist/workers/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsup --config tsup.react-client.config.ts && tsup --config tsup.ui.config.ts",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate --dialect=postgresql --schema=./src/adapters/drizzle/schema.ts --out=./drizzle",
    "lint": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run test:coverage && npm run build",
    "audit:security": "npm audit --omit=dev --audit-level=high",
    "audit:security:all": "npm audit",
    "prepare:release": "node scripts/prepare-release.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "drizzle-orm": ">=0.45.2",
    "next": ">=14.0.0",
    "nodemailer": ">=9.0.1",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "nodemailer": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@opentelemetry/api": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/nodemailer": "^6.4.17",
    "@vitest/coverage-v8": "^2.1.9",
    "drizzle-kit": "^0.31.0",
    "drizzle-orm": "^0.45.2",
    "next": "^16.0.0",
    "nodemailer": "^9.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
