{
  "name": "@tgoliveira/outpost",
  "version": "1.0.0",
  "description": "A transactional outbox with pluggable transport for Next.js. Durable, at-most-once, auditable transactional email.",
  "keywords": [
    "outbox",
    "transactional-email",
    "email",
    "nextjs",
    "drizzle",
    "postgres",
    "clean-architecture",
    "idempotency",
    "suppression-list",
    "smtp",
    "resend"
  ],
  "license": "MIT",
  "author": "Engineering",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js",
      "require": "./dist/adapters/index.cjs"
    },
    "./drizzle": {
      "types": "./dist/adapters/drizzle/index.d.ts",
      "import": "./dist/adapters/drizzle/index.js",
      "require": "./dist/adapters/drizzle/index.cjs"
    },
    "./next": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js",
      "require": "./dist/http/index.cjs"
    },
    "./workers": {
      "types": "./dist/workers/index.d.ts",
      "import": "./dist/workers/index.js",
      "require": "./dist/workers/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate --dialect=postgresql --schema=./src/adapters/drizzle/schema.ts --out=./drizzle",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "drizzle-orm": ">=0.45.2",
    "nodemailer": ">=9.0.1"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "nodemailer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@opentelemetry/api": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "@vitest/coverage-v8": "^2.1.9",
    "drizzle-kit": "^0.31.0",
    "drizzle-orm": "^0.45.2",
    "nodemailer": "^9.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
