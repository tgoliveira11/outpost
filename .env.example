# =============================================================================
# Outpost — example environment for a CONSUMING application
# =============================================================================
# Copy to `.env` (or load via your secret manager) and fill in real values.
# Outpost reads NOTHING from the environment itself — these are the values YOU
# pass into `createOutpost(...)`. Treat every secret here as production-grade:
# keep them in a KMS / secret manager, never commit real values.

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
# Postgres connection string for the Drizzle adapter. The outbox, audit,
# suppression, api_keys and webhook_events tables live here. This is the single
# source of truth — workers poll it.
DATABASE_URL=postgres://user:password@localhost:5432/outpost

# -----------------------------------------------------------------------------
# Recipient HMAC key (required)
# -----------------------------------------------------------------------------
# Keyed HMAC-SHA256 over the (normalized) recipient address. Backs suppression
# matching and recipient-keyed lookups even when encryption-at-rest is OFF.
# MUST be >= 16 bytes of entropy and MUST stay stable for the life of the data:
# changing it orphans every suppression entry and breaks recipient lookups.
# Keep it OUTSIDE the database (secret manager), never in a column.
#
# Generate one:
#   openssl rand -base64 32
OUTPOST_HMAC_KEY=replace-with-output-of-openssl-rand-base64-32

# -----------------------------------------------------------------------------
# Resend provider (required if using ResendEmailProvider)
# -----------------------------------------------------------------------------
# API key from the Resend dashboard. Used by the send worker to dispatch mail.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Signing secret for verifying inbound Resend webhooks (delivered / bounced /
# complained). The webhook sink verifies the signature on the RAW body before
# trusting anything; unverified webhooks are rejected.
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Encryption at rest (optional — off by default)
# -----------------------------------------------------------------------------
# This protects PII (body + recipient) at rest (leaked dump, stolen backup,
# curious DBA). It is NOT end-to-end: the provider still receives readable mail.
#
# Symmetric mode — one 32-byte AES-256-GCM key seals and opens. Simplest:
#   encryption: { mode: "symmetric", key: process.env.OUTPOST_ENCRYPTION_KEY }
#   Generate: openssl rand -base64 32
# OUTPOST_ENCRYPTION_KEY=replace-with-output-of-openssl-rand-base64-32
#
# Asymmetric mode — least-privilege split. The web/ingestion tier seals with the
# PUBLIC key and physically cannot read bodies back; only the send worker, which
# holds the PRIVATE key, can decrypt. Omit the private key on the web tier.
#   encryption: { mode: "asymmetric", publicKey, privateKey }
#
# Generate an RSA keypair:
#   openssl genrsa -out outpost-private.pem 4096
#   openssl rsa -in outpost-private.pem -pubout -out outpost-public.pem
# Then load the PEM contents into these vars (or read the files at boot).
# Web/ingestion tier: set PUBLIC only.   Send worker: set BOTH.
# OUTPOST_ENCRYPTION_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# OUTPOST_ENCRYPTION_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
#
# Production: prefer bringing your own KMS/Vault-backed Encryptor pair instead
# of holding raw key material in env vars. See docs/security.md.
